<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Nebula Vape Co.</title>

<style>
body{margin:0;font-family:Arial;background:#000;color:#fff;}

.hero{
background:url('https://blog.contraelcancer.es/wp-content/uploads/2023/02/vapeadores-dejar-de-fumar.jpg') center/cover;
padding:100px 20px;text-align:center;
}

.overlay{
background:rgba(0,0,0,0.7);
padding:30px;border-radius:15px;display:inline-block;
}

.productos{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;padding:20px;
}

.card{
background:#1a1a1a;padding:15px;border-radius:15px;text-align:center;
}

.card img{
width:100%;height:150px;object-fit:cover;border-radius:10px;
}

button{
background:#25D366;border:none;padding:10px;border-radius:8px;color:#fff;cursor:pointer;
}

.carrito{
background:#111;padding:20px;margin:20px;border-radius:15px;
}

.chatbot{
position:fixed;bottom:20px;right:20px;width:280px;background:#111;border-radius:10px;
}

.chat-header{
background:#25D366;padding:10px;text-align:center;cursor:pointer;
}

.chat-body{
height:260px;overflow-y:auto;padding:10px;
}

.msg{margin:5px 0;}
.bot{color:#0f0;}
.user{color:#fff;}

input{width:100%;padding:10px;border:none;}
</style>
</head>

<body>

<header class="hero">
  <div class="overlay">
    <h1>Nebula Vape Co 🔥</h1>
    <p>Experiencia premium en vapeo en Colombia</p>
  </div>
</header>

<section id="productos" class="productos"></section>

<div class="carrito">
<h2>Carrito</h2>
<ul id="lista"></ul>
<p id="total">Total: $0</p>
<button onclick="comprar()">Finalizar pedido</button>
</div>

<div class="chatbot">
<div class="chat-header" onclick="toggleChat()">ANGELA 💬</div>
<div id="chatBody" class="chat-body"></div>
<input id="userInput" placeholder="Escribe..." onkeypress="handleKey(event)">
</div>

<script>
// ===== PRODUCTOS =====
const productos = [
{nombre:"Vape Mango Ice", precio:95000, tipo:"vape", img:"https://cityvape.eu/6843-large_default/elf-bar-600-mango-ice.jpg", desc:"Sabor mango con toque frío"},
{nombre:"Vape Blueberry", precio:97000, tipo:"vape", img:"https://www.vape-schweiz.ch/wp-content/uploads/2024/11/elfbar-600-blueberry.jpg.webp", desc:"Arándano dulce intenso"},
{nombre:"Vape Strawberry", precio:95000, tipo:"vape", img:"https://images.rappi.com/products/1717346905543_1717346901432_1717346900429.jpeg?d=900x750&e=webp&q=30", desc:"Fresa fresca suave"},
{nombre:"Cargador USB Vape", precio:20000, tipo:"cargador", img:"https://images.rappi.com/products/1736796227091_1736796222385_1736796228453.jpg?d=900x750&e=webp&q=30", desc:"Carga rápida universal"},
{nombre:"Cargador Tipo C", precio:25000, tipo:"cargador", img:"https://http2.mlstatic.com/D_NQ_NP_2X_979877-MCO99007784968_112025-F.webp", desc:"Alta velocidad tipo C"},
{nombre:"Esencia Menta", precio:30000, tipo:"esencia", img:"https://www.vapeototal.net/blog/wp-content/uploads/2022/03/super-ice-menthol.jpg", desc:"Refrescante y fuerte"},
{nombre:"Esencia Vainilla", precio:32000, tipo:"esencia", img:"https://yovapeo.com/88-thickbox_default/vainilla.jpg", desc:"Dulce suave premium"}
];

let carrito=[];
let contexto={
etapa:"nombre",
nombre:"",
interes:null,
intentos:0
};

// ===== RENDER =====
function render(){
const cont=document.getElementById("productos");
cont.innerHTML="";
productos.forEach((p,i)=>{
cont.innerHTML+=`
<div class="card">
<img src="${p.img}">
<h3>${p.nombre}</h3>
<p>${p.desc}</p>
<p>$${p.precio.toLocaleString("es-CO")}</p>
<button onclick="agregar(${i})">Agregar</button>
</div>`;
});
}

function agregar(i){
carrito.push(productos[i]);
actualizar();
}

function actualizar(){
let total=0;
const lista=document.getElementById("lista");
lista.innerHTML="";
carrito.forEach(p=>{
total+=p.precio;
lista.innerHTML+=`<li>${p.nombre}</li>`;
});
document.getElementById("total").innerText="Total: $"+total.toLocaleString("es-CO");
}

// ===== CHAT =====
function addMsg(text,tipo){
const chat=document.getElementById("chatBody");
chat.innerHTML+=`<div class="msg ${tipo}">${text}</div>`;
chat.scrollTop=chat.scrollHeight;
}

function toggleChat(){
const body=document.getElementById("chatBody");
const input=document.getElementById("userInput");
body.style.display = body.style.display==="none"?"block":"none";
input.style.display = input.style.display==="none"?"block":"none";
}

// ===== CHATBOT =====
function responder(text){

// PEDIR NOMBRE
if(contexto.etapa==="nombre"){
addMsg("👋 Hola! Soy Angela","bot");
addMsg("¿Cómo te llamas?","bot");
contexto.etapa="guardarNombre";
return;
}

// GUARDAR NOMBRE
if(contexto.etapa==="guardarNombre"){
contexto.nombre=text.charAt(0).toUpperCase()+text.slice(1);
addMsg("Mucho gusto "+contexto.nombre+" 😄","bot");
addMsg("¿Qué estás buscando? Vape, esencia o cargador","bot");
contexto.etapa="descubrir";
return;
}

// RESPUESTAS GENERALES
if(text.includes("pago")){
addMsg("💳 Métodos de pago:\n- Nequi\n- Daviplata\n- Efectivo","bot");
return;
}

// DESCUBRIR
if(contexto.etapa==="descubrir"){
if(text.includes("vape")){
contexto.interes="vape";
addMsg(contexto.nombre+", ¿prefieres dulce o fresco?","bot");
contexto.etapa="perfil";return;
}
if(text.includes("esencia")){
contexto.interes="esencia";
addMsg("¿Te gusta suave o fuerte?","bot");
contexto.etapa="perfil";return;
}
if(text.includes("cargador")){
contexto.interes="cargador";
addMsg("USB o Tipo C","bot");
contexto.etapa="perfil";return;
}
addMsg("¿Vape, esencia o cargador?","bot");return;
}

// PERFIL
if(contexto.etapa==="perfil"){

if(contexto.interes==="vape"){
if(text.includes("dulce")) agregarPorNombre("blueberry");
else agregarPorNombre("mango");
}

if(contexto.interes==="esencia"){
if(text.includes("fuerte")) agregarPorNombre("menta");
else agregarPorNombre("vainilla");
}

if(contexto.interes==="cargador"){
if(text.includes("tipo")) agregarPorNombre("tipo c");
else agregarPorNombre("usb");
}

addMsg("🔥 Listo "+contexto.nombre+", te agregué una opción","bot");
addMsg("💳 Puedes pagar con Nequi, Daviplata o efectivo","bot");
addMsg("¿Quieres algo más o finalizamos?","bot");

contexto.etapa="venta";
return;
}

// CIERRE
if(contexto.etapa==="venta"){
if(text.includes("si")){
contexto.etapa="descubrir";
addMsg("Perfecto "+contexto.nombre+", ¿qué más buscas?","bot");
return;
}
if(text.includes("no")||text.includes("final")){
addMsg("🛒 Dale clic en finalizar pedido","bot");
addMsg("🚀 Gracias por tu compra "+contexto.nombre,"bot");
return;
}

contexto.intentos++;
if(contexto.intentos===1){
addMsg("💡 Puedes agregar esencia o cargador","bot");
}else{
addMsg("¿Finalizamos compra?","bot");
}
}
}

// ===== FUNCIONES =====
function agregarPorNombre(nombre){
const p=productos.find(x=>x.nombre.toLowerCase().includes(nombre));
if(p){carrito.push(p);actualizar();}
}

function handleKey(e){
if(e.key==="Enter"){
const input=document.getElementById("userInput");
const text=input.value.toLowerCase();
if(text==="") return;
addMsg(input.value,"user");
responder(text);
input.value="";
}
}

function comprar(){
let msg="Pedido de "+contexto.nombre+":\n";
carrito.forEach(p=>msg+=p.nombre+" - $"+p.precio+"\n");
window.open("https://wa.me/573001234567?text="+encodeURIComponent(msg));
}

// INIT
window.onload=()=>{
render();
responder("");
};
</script>

</body>
</html>
